# Copy to .env (same folder, git-ignored) for local runs of settlrl-app. Read by
# settlrl_app.config at startup; a real environment variable of the same name
# overrides any value here, and a missing file is a no-op. SETTLRL_APP_* keys
# only — see packages/settlrl-app/README.md "Hosting".

# Comma-separated emails granted admin (superuser) on register / login.
SETTLRL_APP_ADMIN_EMAILS=you@example.com

# Where games + accounts are journalled (a SQLite db here). Omit for in-memory.
# SETTLRL_APP_STATE_DIR=./state
