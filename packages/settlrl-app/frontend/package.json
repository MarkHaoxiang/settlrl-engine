    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "openapi-typescript": "^7.13.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.5.3",
    "vite": "^8.0.14"
  }
