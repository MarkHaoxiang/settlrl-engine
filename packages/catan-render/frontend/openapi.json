    "parameters": [
     {
      "name": "game_id",
      "in": "path",
      "required": true,
      "schema": {
       "type": "string",
       "title": "Game Id"
      }
     },
     {
      "name": "X-Seat-Tokens",
      "in": "header",
      "required": false,
      "schema": {
       "anyOf": [
