       }
      }
     },
     "422": {
      "description": "Validation Error",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    }
   }
  },
  "/api/games/{game_id}/record": {
   "get": {
    "summary": "Get Record",
    "description": "The finished game as ``catan_engine.record`` JSON -- a\nself-contained, replayable transcript. 409 while running: replaying a\nrecord reconstructs hidden hands, so live games don't export.",
    "operationId": "get_record_api_games__game_id__record_get",
    "parameters": [
     {
      "name": "game_id",
      "in": "path",
      "required": true,
      "schema": {
       "type": "string",
       "title": "Game Id"
      }
     }
    ],
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {}
       }
      }
     },
     "422": {
      "description": "Validation Error",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    }
   }
  },
  "/api/games/{game_id}/replay": {
   "post": {
    "summary": "Post Replay From Game",
    "description": "Load a finished game for replay (409 while it is still running:\nreplaying reconstructs hidden hands).",
    "operationId": "post_replay_from_game_api_games__game_id__replay_post",
    "parameters": [
     {
      "name": "game_id",
      "in": "path",
      "required": true,
      "schema": {
       "type": "string",
       "title": "Game Id"
      }
     }
    ],
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/ReplayStateModel"
        }
       }
      }
     },
     "422": {
      "description": "Validation Error",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    }
   }
  },
  "/api/replay": {
   "post": {
    "summary": "Post Replay",
    "description": "Load a game record (the ``catan_engine.record`` JSON document) for\nreplay; returns the opening state. ``422`` if the record is malformed\nor fails replay validation.",
    "operationId": "post_replay_api_replay_post",
    "requestBody": {
     "content": {
      "application/json": {
       "schema": {
        "additionalProperties": true,
        "type": "object",
        "title": "Doc"
       }
      }
     },
     "required": true
    },
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/ReplayStateModel"
        }
       }
      }
     },
     "422": {
      "description": "Validation Error",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    }
   }
  },
  "/api/replay/state": {
   "get": {
    "summary": "Get Replay State",
    "description": "The loaded replay after ``move`` moves (0 = the opening board).\n\n``404`` when no replay is loaded; ``422`` when ``move`` is out of\nrange.",
    "operationId": "get_replay_state_api_replay_state_get",
    "parameters": [
     {
      "name": "move",
      "in": "query",
      "required": false,
      "schema": {
       "type": "integer",
       "default": 0,
       "title": "Move"
      }
     }
    ],
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/ReplayStateModel"
        }
       }
      }
     },
     "422": {
      "description": "Validation Error",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    }
   }
  },
  "/api/replay/record": {
   "get": {
    "summary": "Get Replay Record",
    "description": "The loaded replay's record JSON (e.g. to save it to a file).",
    "operationId": "get_replay_record_api_replay_record_get",
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {}
       }
      }
     }
    }
   }
  },
  "/api/bots": {
   "get": {
    "summary": "Get Bots",
    "description": "Bot kinds available for seats (catan-agents names), each with the\nplayer counts it supports and its configurable build parameters.",
    "operationId": "get_bots_api_bots_get",
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {
         "additionalProperties": {
          "additionalProperties": true,
          "type": "object"
         },
         "type": "object",
         "title": "Response Get Bots Api Bots Get"
        }
       }
      }
     }
    }
   }
  }
 },
 "components": {
  "schemas": {
   "ActionModel": {
    "properties": {
     "flat": {
      "type": "integer",
      "title": "Flat"
     },
     "type": {
      "type": "string",
      "title": "Type"
     },
     "label": {
      "type": "string",
      "title": "Label"
     },
     "vertex": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/CubeModel"
       },
       {
        "type": "null"
       }
      ]
     },
     "edge": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/EdgeModel"
       },
       {
        "type": "null"
       }
      ]
     },
     "tile": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/HexModel"
       },
       {
        "type": "null"
       }
      ]
     },
     "victim": {
      "anyOf": [
       {
        "type": "integer"
       },
       {
        "type": "null"
       }
      ],
      "title": "Victim"
     },
     "resource": {
      "anyOf": [
       {
        "type": "string"
       },
       {
        "type": "null"
       }
      ],
      "title": "Resource"
     },
     "resources": {
      "anyOf": [
       {
        "items": {
         "type": "string"
        },
        "type": "array"
       },
       {
        "type": "null"
       }
      ],
      "title": "Resources"
     },
     "give": {
      "anyOf": [
       {
        "type": "string"
       },
       {
        "type": "null"
       }
      ],
      "title": "Give"
     },
     "receive": {
      "anyOf": [
       {
        "type": "string"
       },
       {
        "type": "null"
       }
      ],
      "title": "Receive"
     },
     "partner": {
      "anyOf": [
       {
        "type": "integer"
       },
       {
        "type": "null"
       }
      ],
      "title": "Partner"
     }
    },
    "type": "object",
    "required": [
     "flat",
     "type",
     "label"
    ],
    "title": "ActionModel",
    "description": "One legal move for the acting player, decoded from the AEC flat action set.\n\n``flat`` is the engine's flat action index (post it back to apply the move).\n``type`` is the lowercased :class:`ActionType` name. Depending on the type, at\nmost one geometry/resource group below is populated; the rest stay ``None``."
   },
   "BankModel": {
    "properties": {
     "resources": {
      "$ref": "#/components/schemas/ResourceCounts"
     },
     "dev_cards": {
      "type": "integer",
      "title": "Dev Cards"
     }
    },
    "type": "object",
    "required": [
     "resources",
     "dev_cards"
    ],
    "title": "BankModel",
    "description": "Cards left in the supply: resource stacks plus the development deck."
   },
   "BeliefModel": {
    "properties": {
     "observer": {
      "type": "integer",
      "title": "Observer"
     },
     "players": {
      "items": {
       "$ref": "#/components/schemas/PlayerBeliefModel"
      },
      "type": "array",
      "title": "Players"
     }
    },
    "type": "object",
    "required": [
     "observer",
     "players"
    ],
    "title": "BeliefModel",
    "description": "Card counting from one human seat's perspective.\n\nEverything here is derivable from public information (the engine's belief\ntracker), so showing it to that seat never leaks hidden state. The\nobserver's own row is omitted \u2014 their hand is already on screen."
   },
   "BoardModel": {
    "properties": {
     "tiles": {
      "items": {
       "$ref": "#/components/schemas/TileModel"
      },
      "type": "array",
      "title": "Tiles"
     },
     "buildings": {
      "items": {
       "$ref": "#/components/schemas/BuildingModel"
      },
      "type": "array",
      "title": "Buildings",
      "default": []
     },
     "roads": {
      "items": {
       "$ref": "#/components/schemas/RoadModel"
      },
      "type": "array",
      "title": "Roads",
      "default": []
     },
     "ports": {
      "items": {
       "$ref": "#/components/schemas/PortModel"
      },
      "type": "array",
      "title": "Ports",
      "default": []
     },
     "players": {
      "items": {
       "$ref": "#/components/schemas/PlayerModel"
      },
      "type": "array",
      "title": "Players",
      "default": []
     },
     "robber": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/HexModel"
       },
       {
        "type": "null"
       }
      ]
     },
     "bank": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/BankModel"
       },
       {
        "type": "null"
       }
      ]
     }
    },
    "type": "object",
    "required": [
     "tiles"
    ],
    "title": "BoardModel"
   },
   "BotMoveModel": {
    "properties": {
     "player": {
      "type": "integer",
      "title": "Player"
     },
     "action": {
      "$ref": "#/components/schemas/ActionModel"
     }
    },
    "type": "object",
    "required": [
     "player",
     "action"
    ],
    "title": "BotMoveModel",
    "description": "One just-played bot move: the seat that acted and the decoded action."
   },
   "BuildingModel": {
    "properties": {
     "cube": {
      "$ref": "#/components/schemas/CubeModel"
     },
     "player": {
      "type": "integer",
      "title": "Player"
     },
     "kind": {
      "type": "string",
      "enum": [
       "settlement",
       "city"
      ],
      "title": "Kind"
     }
    },
    "type": "object",
    "required": [
     "cube",
     "player",
     "kind"
    ],
    "title": "BuildingModel",
    "description": "A settlement or city sitting on a vertex, owned by a 0-indexed player."
   },
   "CubeModel": {
    "properties": {
     "q": {
      "type": "integer",
      "title": "Q"
     },
     "r": {
      "type": "integer",
      "title": "R"
     },
     "s": {
      "type": "integer",
      "title": "S"
     }
    },
    "type": "object",
    "required": [
     "q",
     "r",
     "s"
    ],
    "title": "CubeModel",
    "description": "A board vertex, in the engine's cube coordinates (q + r + s = \u00b11)."
   },
   "DevCardCounts": {
    "properties": {
     "knight": {
      "type": "integer",
      "title": "Knight"
     },
     "road_building": {
      "type": "integer",
      "title": "Road Building"
     },
     "year_of_plenty": {
      "type": "integer",
      "title": "Year Of Plenty"
     },
     "monopoly": {
      "type": "integer",
      "title": "Monopoly"
     },
     "victory_point": {
      "type": "integer",
      "title": "Victory Point"
     }
    },
    "type": "object",
    "required": [
     "knight",
     "road_building",
     "year_of_plenty",
     "monopoly",
     "victory_point"
    ],
    "title": "DevCardCounts",
    "description": "Unplayed development cards in hand, by type (DevCard order)."
   },
   "EdgeModel": {
    "properties": {
     "a": {
      "$ref": "#/components/schemas/CubeModel"
     },
     "b": {
      "$ref": "#/components/schemas/CubeModel"
     }
    },
    "type": "object",
    "required": [
     "a",
     "b"
    ],
    "title": "EdgeModel",
    "description": "A board edge between two vertices (in cube coordinates)."
   },
   "GameModel": {
    "properties": {
     "id": {
      "type": "string",
      "title": "Id"
     },
     "board": {
      "$ref": "#/components/schemas/BoardModel"
     },
     "status": {
      "$ref": "#/components/schemas/GameStatusModel"
     },
     "actions": {
      "items": {
       "$ref": "#/components/schemas/ActionModel"
      },
      "type": "array",
      "title": "Actions",
      "default": []
     },
     "bot_move": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/BotMoveModel"
       },
       {
        "type": "null"
       }
      ]
     },
     "log": {
      "items": {
       "$ref": "#/components/schemas/LogEntryModel"
      },
      "type": "array",
      "title": "Log",
      "default": []
     },
     "belief": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/BeliefModel"
       },
       {
        "type": "null"
       }
      ]
     },
     "seats_claimed": {
      "items": {
       "type": "integer"
      },
      "type": "array",
      "title": "Seats Claimed",
      "default": []
     }
    },
    "type": "object",
    "required": [
     "id",
     "board",
     "status"
    ],
    "title": "GameModel",
    "description": "One requester's snapshot: board + status + their legal moves.\n\nViews are per-seat: ``your_turn`` / ``actions`` / unredacted hands /\n``belief`` follow the seats the request's tokens prove."
   },
   "GameStatusModel": {
    "properties": {
     "phase": {
      "type": "string",
      "title": "Phase"
     },
     "current_player": {
      "type": "integer",
      "title": "Current Player"
     },
     "acting_player": {
      "type": "integer",
      "title": "Acting Player"
     },
     "dice_roll": {
      "type": "integer",
      "title": "Dice Roll"
     },
     "has_rolled": {
      "type": "boolean",
      "title": "Has Rolled"
     },
     "your_turn": {
      "type": "boolean",
      "title": "Your Turn"
     },
     "terminal": {
      "type": "boolean",
      "title": "Terminal"
     },
     "winner": {
      "anyOf": [
       {
        "type": "integer"
       },
       {
        "type": "null"
       }
      ],
      "title": "Winner"
     },
     "seats": {
      "items": {
       "type": "string"
      },
      "type": "array",
      "title": "Seats",
      "default": []
     },
     "trade": {
      "anyOf": [
       {
        "$ref": "#/components/schemas/TradeOfferModel"
       },
       {
        "type": "null"
       }
      ]
     }
    },
    "type": "object",
    "required": [
     "phase",
     "current_player",
     "acting_player",
     "dice_roll",
