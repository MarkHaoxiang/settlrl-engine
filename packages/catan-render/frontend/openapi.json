       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    }
   }
  },
  "/api/games/{game_id}/chat": {
   "post": {
    "summary": "Post Chat",
    "description": "Append a chat message to the game log.",
    "operationId": "post_chat_api_games__game_id__chat_post",
    "parameters": [
     {
      "name": "game_id",
      "in": "path",
      "required": true,
      "schema": {
       "type": "string",
       "title": "Game Id"
      }
     },
     {
      "name": "X-Seat-Tokens",
      "in": "header",
      "required": false,
      "schema": {
       "anyOf": [
        {
         "type": "string"
        },
        {
         "type": "null"
        }
       ],
       "title": "X-Seat-Tokens"
      }
     }
    ],
    "requestBody": {
     "required": true,
     "content": {
      "application/json": {
