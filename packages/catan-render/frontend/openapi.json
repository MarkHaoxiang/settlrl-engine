  "/api/games/{game_id}/bot": {
   "post": {
    "summary": "Post Bot Step",
    "description": "Play one due bot move; the snapshot plus what was played\n(``bot_move``, null when no bot move was due).",
    "operationId": "post_bot_step_api_games__game_id__bot_post",
    "parameters": [
     {
      "name": "game_id",
      "in": "path",
      "required": true,
      "schema": {
       "type": "string",
       "title": "Game Id"
      }
     },
     {
      "name": "X-Seat-Tokens",
      "in": "header",
      "required": false,
      "schema": {
       "anyOf": [
        {
         "type": "string"
        },
        {
         "type": "null"
        }
       ],
       "title": "X-Seat-Tokens"
      }
     }
    ],
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/GameModel"
        }
       }
